# =============================================================================
# AI Scraping Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- Database ---
# NOTE: URL-encode special chars in password (# → %23, @ → %40, etc.)
# Quote values containing special characters with double quotes.
DATABASE_URL="postgresql+asyncpg://scraper:scraper@localhost:5432/scraper_db"
# For desktop/local mode, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./scraper.db
#
# IMPORTANT — Supabase on Railway/Render/Vercel:
# Direct URLs (db.<ref>.supabase.co:5432) use IPv6 ONLY and will NOT work.
# Use the Session pooler URL from: Supabase dashboard → Connect → Session pooler.
# DATABASE_URL="postgresql+asyncpg://postgres.<ref>:password%23etc@aws-N-<region>.pooler.supabase.com:5432/postgres"
# Note: the cluster number (aws-0, aws-1, etc.) varies per project — copy from dashboard.

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# For desktop/local mode, leave empty to use in-memory queue

# --- Queue Backend ---
QUEUE_BACKEND=redis
# Options: redis, memory
# Use "memory" for desktop/local mode, "redis" for production

# --- Object Storage ---
STORAGE_TYPE=filesystem
# Options: filesystem, s3
STORAGE_PATH=./artifacts
# For S3:
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=scraper-artifacts
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# --- AI Providers ---
# Google Gemini (default, free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (optional fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (optional, for local/self-hosted AI)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- External Adapters (optional, not part of default chain) ---
# APIFY_API_KEY=            # Only if you opt-in to Apify as a fallback lane
# KEEPA_API_KEY=            # Keepa.com API key for Amazon product data (replaces browser scraping)

# --- Google Sheets (Keepa cache layer) ---
# GOOGLE_SHEETS_CREDENTIALS_FILE=./service_account.json   # Path to service account JSON key
# GOOGLE_SHEETS_SPREADSHEET_ID=                            # Google Sheet document ID
# GOOGLE_SHEETS_CREDENTIALS_JSON=                          # Alternative: paste full JSON as string

# --- Google OAuth (for Sheets write access via OAuth2) ---
# GOOGLE_CLIENT_ID=                # Google OAuth2 client ID
# GOOGLE_CLIENT_SECRET=            # Google OAuth2 client secret

# --- Google Maps ---
# GOOGLE_MAPS_API_KEY=           # Google Places API key (primary, ~$0.032/request)
# SERPAPI_KEY=                    # SerpAPI key (secondary fallback, ~$0.01/search)
# (No key needed for browser scraping fallback — uses stealth stack)

# --- Proxy ---
# PROXY_PROVIDER=file
# PROXY_FILE=./proxies.txt
# PROXY_API_URL=
# PROXY_API_KEY=

# --- CAPTCHA ---
# CAPTCHA_PROVIDER=2captcha
# CAPTCHA_API_KEY=
# NOPECHA_API_KEY=

# --- Authentication ---
# SECRET_KEY is used for JWT token signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=100

# --- Worker Concurrency ---
HTTP_WORKER_CONCURRENCY=5
BROWSER_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=3
HARD_TARGET_WORKER_CONCURRENCY=1

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Comma-separated list of allowed origins. Use "*" for development only.

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4

# --- Multi-Tenant (SaaS mode only) ---
# BILLING_ENABLED=false
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Observability ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# PROMETHEUS_ENABLED=true
