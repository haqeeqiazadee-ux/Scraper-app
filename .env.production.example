# =============================================================================
# AI Scraping Platform — Production Environment (Netlify + Supabase + Railway)
# =============================================================================
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# ─── Supabase (PostgreSQL) ───────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Use the "URI" format with connection pooler (port 6543) for serverless
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Your Supabase project URL (for reference)
# SUPABASE_URL=https://pspnuohejsbcavdtardv.supabase.co
# SUPABASE_ANON_KEY=  # Only needed if using Supabase Auth directly

# ─── Redis (Railway Plugin) ─────────────────────────────────────────────────
# Railway auto-injects REDIS_URL when you add a Redis plugin
REDIS_URL=redis://default:PASSWORD@HOST:PORT
QUEUE_BACKEND=redis

# ─── Object Storage ─────────────────────────────────────────────────────────
# Use Supabase Storage (S3-compatible) or Railway volume
STORAGE_TYPE=filesystem
STORAGE_PATH=/app/artifacts
# For Supabase Storage (S3-compatible):
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://pspnuohejsbcavdtardv.supabase.co/storage/v1/s3
# S3_BUCKET=artifacts
# S3_ACCESS_KEY=  # From Supabase Dashboard → Storage → S3 Access Keys
# S3_SECRET_KEY=
# S3_REGION=auto

# ─── AI Providers ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (optional fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ───────────────────────────────────────────────────────────────────
# Set to your Netlify domain once deployed
CORS_ORIGINS=https://YOUR-SITE.netlify.app,http://localhost:5173

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=100

# ─── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4

# ─── Worker Concurrency ─────────────────────────────────────────────────────
HTTP_WORKER_CONCURRENCY=5
BROWSER_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=3
HARD_TARGET_WORKER_CONCURRENCY=1

# ─── Netlify (set in Netlify Dashboard → Build & Deploy → Environment) ──────
# VITE_API_URL=https://YOUR-RAILWAY-URL.railway.app/api/v1
