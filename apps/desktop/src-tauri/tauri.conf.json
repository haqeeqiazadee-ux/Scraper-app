{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AI Scraper",
  "version": "0.1.0",
  "identifier": "com.scraper.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "AI Scraper",
    "windows": [
      {
        "title": "AI Scraper",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "AI Scraper"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../installer/license.rtf"
    ],
    "fileAssociations": [
      {
        "ext": ["scraper-task"],
        "mimeType": "application/x-scraper-task",
        "description": "AI Scraper Task File",
        "role": "Editor"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "license": "../../installer/license.rtf",
        "bannerPath": "../../installer/banner.bmp",
        "dialogImagePath": "../../installer/dialog.bmp",
        "language": "en-US",
        "template": null,
        "fragmentPaths": [],
        "componentGroupRefs": [],
        "componentRefs": [],
        "customActionRefs": [],
        "featureGroupRefs": [],
        "featureRefs": [],
        "mergeRefs": [],
        "skipWebviewInstall": false,
        "fipsCompliant": false
      },
      "nsis": {
        "headerImage": "../../installer/header.bmp",
        "sidebarImage": "../../installer/sidebar.bmp",
        "license": "../../installer/license.rtf",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "currentUser",
        "startMenuFolder": "AI Scraper",
        "template": null
      }
    },
    "shortDescription": "AI-powered web scraping platform",
    "longDescription": "AI Scraper is a production-grade, cloud-agnostic AI-powered web scraping platform. It provides intelligent extraction with automatic lane routing, fallback chains, and AI normalization.",
    "copyright": "Copyright (c) 2026 AI Scraper Team",
    "category": "Utility",
    "publisher": "AI Scraper Team"
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-server",
          "cmd": "python",
          "args": [
            "-m",
            "uvicorn",
            "services.control_plane.app:app",
            "--host",
            "127.0.0.1",
            "--port",
            "8321"
          ]
        }
      ]
    }
  }
}
