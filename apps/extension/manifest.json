{
  "manifest_version": 3,
  "name": "AI Scraper",
  "version": "0.1.0",
  "description": "AI-powered web scraping — extract structured data from any page.",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "nativeMessaging",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.aiscraper.io/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "content/selector-picker.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
