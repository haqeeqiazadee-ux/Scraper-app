# Hostinger MySQL — copy this file to `.env` and fill in real values.
# Do not commit `.env` if it contains secrets.
#
# Either style works for Python (core/database.py) and index.php:
#   DB_USER / DB_PASS / DB_NAME   OR   DB_USERNAME / DB_PASSWORD / DB_DATABASE
# Optional: DB_PORT=3306

# Host for Python / remote tools (from your PC), e.g. Hostinger remote MySQL IP
DB_HOST=your-mysql-host.hstgr.io
# Required on Hostinger ``public_html`` .env for PHP: use localhost (omit only if you rely on auto-retry in index.php)
DB_HOST_WEB=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASS=your_mysql_password
DB_NAME=your_database_name

# Set to 1 in .env temporarily to show the real SQL/PDO error on the yellow alert
# APP_DEBUG=1

# Vendor A CSV ingest (local path)
VENDOR_A_CSV_PATH=C:\\path\\to\\vendor_a_catalog.csv
# Optional: stored on vendor_offers.vendor_name
VENDOR_A_NAME=Vendor A
# Optional — feed automation (run_feeds.py sets these by default when stamp_ingest is on):
# VENDOR_OFFERS_SNAPSHOT=1   # drop vendor_offers not in this feed; update others only if price/stock changed
# VENDOR_A_IN_STOCK_ONLY=1   # CSV ingest: skip rows unless stock column > 0

# Read API (optional): ``python -m api.main`` or ``uvicorn api.main:app --host 0.0.0.0 --port 8080``
# B2B_API_PORT=8080
# B2B_API_KEY=generate-a-long-random-string
# B2B_CORS_ORIGINS=*
# FMS PHP (optional): public base URL of the FastAPI service — shown on ?view=api for OpenAPI /docs link
# B2B_API_BASE_URL=http://localhost:8080

# Fixed FX (EUR pivot). Ingest fills GBP + EUR + USD on every offer from the feed's single price.
# GBP = EUR * B2B_FX_GBP_PER_EUR   |   USD = EUR * B2B_FX_USD_PER_EUR
# Adjust to your desk rates; defaults match Python if omitted.
# B2B_FX_GBP_PER_EUR=0.86
# B2B_FX_USD_PER_EUR=1.08
